# Supabase - ignored for now
/supabase/
/*.sql

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/.next-dev/
/.next-build-test/
/.next.corrupt-*/
/.next-dev.corrupt-*/
/.next.corrupt-manual-*/
/.next.pre-fix-backup-*/
/.next.watchdog-*/
/dist/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# other
.idea/
/artifacts/
/.worktrees/
/AGENTS_LOG.md
/docs/superpowers/

